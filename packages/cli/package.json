{
  "name": "monkeywrench",
  "version": "0.0.1",
  "description": "npm package naming toolkit — generate, check, and score package names",
  "keywords": ["npm", "package", "naming", "cli", "squatter", "availability"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zrosenbauer/monkeywrench.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "monkeywrench": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "kidd dev",
    "build": "kidd build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kidd-cli/core": "^0.23.1",
    "@monkeywrench/core": "workspace:*",
    "@monkeywrench/data": "workspace:*",
    "@monkeywrench/db": "workspace:*",
    "@monkeywrench/types": "workspace:*",
    "ink": "^7.0.0",
    "ink-gradient": "^4.0.0",
    "ink-big-text": "^2.0.0",
    "react": "^19.2.0",
    "ts-pattern": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@kidd-cli/cli": "^0.11.5",
    "@types/react": "^19.2.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0"
  }
}
