{
  "name": "namescout",
  "version": "0.0.1",
  "description": "npm package naming toolkit — generate, check, and score package names",
  "keywords": [
    "availability",
    "cli",
    "naming",
    "npm",
    "package",
    "squatter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zrosenbauer/namescout.git",
    "directory": "packages/cli"
  },
  "bin": {
    "namescout": "./dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "kidd dev",
    "build": "kidd build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kidd-cli/core": "^0.23.1",
    "@namescout/core": "workspace:*",
    "@namescout/data": "workspace:*",
    "@namescout/db": "workspace:*",
    "@namescout/types": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "all-the-package-names": "^2.0.2426",
    "better-sqlite3": "^12.9.0",
    "cmpstr": "^3.3.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "react": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "squatter": "^0.2.1",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kidd-cli/cli": "^0.11.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
